# ── Late API ─────────────────────────────────────────────────────────────────
LATE_API_KEY=sk_xxxxxxxxxxxx
LATE_API_BASE_URL=https://api.getlate.dev
LATE_WEBHOOK_SECRET=your_webhook_secret_here

# ── AWS / MinIO ───────────────────────────────────────────────────────────────
S3_BUCKET=scheduler-videos
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_REGION=eu-west-3
# For local MinIO: http://localhost:9000
# For AWS S3: leave empty (SDK uses default endpoint)
S3_ENDPOINT=http://localhost:9000

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/scheduler
DB_USER=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_very_long_base64_secret_key_at_least_256_bits_here
JWT_EXPIRATION_MS=86400000

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
